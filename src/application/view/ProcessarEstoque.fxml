<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="520.0" prefWidth="750.0"
 xmlns="http://javafx.com/javafx/21"
 xmlns:fx="http://javafx.com/fxml/1"
 fx:controller="application.view.ProcessarEstoque"
 style="-fx-background-color: linear-gradient(to bottom, #0f2027, #203a43, #2c5364);">

    <children>
        <VBox alignment="TOP_CENTER" spacing="20"
              AnchorPane.topAnchor="15.0"
              AnchorPane.leftAnchor="15.0"
              AnchorPane.rightAnchor="15.0"
              AnchorPane.bottomAnchor="15.0">

            <children>

                <Label text="📦 Processar Estoque"
                       style="-fx-font-weight: bold; -fx-text-fill: #ffffff;">
                    <font>
                        <Font size="22.0"/>
                    </font>
                </Label>

                <Separator/>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Pesquisar:" style="-fx-text-fill:#dddddd;"/>
                        <TextField fx:id="txtBuscar" onAction="#buscar"
                                   style="-fx-background-color:#1c1c1c; -fx-text-fill:white;"/>
                        <Button text="Buscar" onAction="#buscar"
                                style="-fx-background-color:#2196F3; -fx-text-fill:white;"/>
                    </children>
                </HBox>

                <GridPane hgap="12" vgap="12">
                    <children>
                        <Label text="ID" style="-fx-text-fill:#dddddd;"/>
                        <Label text="Código de Barras" GridPane.columnIndex="1" style="-fx-text-fill:#dddddd;"/>
                        <Label text="Produto" GridPane.columnIndex="2" style="-fx-text-fill:#dddddd;"/>
                        <Label text="Quantidade" GridPane.columnIndex="3" style="-fx-text-fill:#dddddd;"/>

                        <TextField fx:id="txtId" editable="false" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtCodigoBarras" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtProduto" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtQuantidade" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                    </children>
                </GridPane>

                <HBox spacing="25" alignment="CENTER_RIGHT">

                    <Button text="Histórico" onAction="#abrirHistorico"
                            style="-fx-background-color:#2196F3; -fx-text-fill:white;"/>

                    <Button text="Movimentação" onAction="#abrirMovimentacao"
                            style="-fx-background-color:#9C27B0; -fx-text-fill:white;"/>

                    <VBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="Operação:" style="-fx-font-weight:bold; -fx-text-fill:#ffffff;"/>

                        <RadioButton fx:id="rbEntrada" text="Entrada"
                                     style="-fx-text-fill: white; -fx-font-weight: bold;"/>

                        <RadioButton fx:id="rbSaida" text="Saída"
                                     style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </VBox>

                    <Button text="Atualizar" onAction="#atualizar"
                            style="-fx-background-color:#FF9800; -fx-text-fill:white;"/>

                    <Button text="✔ Processar Estoque" onAction="#processar"
                            style="-fx-background-color:#4CAF50; -fx-text-fill:white;"/>

                </HBox>

                <TableView fx:id="tableProdutos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colID" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colCodigoBarras" text="Código" prefWidth="120"/>
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="150"/>
                        <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="200"/>
                        <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="120"/>
                        <TableColumn fx:id="colQtd" text="Qtd" prefWidth="80"/>
                    </columns>
                </TableView>

            </children>
        </VBox>
    </children>
</AnchorPane>