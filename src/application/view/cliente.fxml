<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: linear-gradient(to bottom, #141e30, #243b55);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.view.ClienteController">

    <children>

        <VBox spacing="15"
              AnchorPane.topAnchor="10"
              AnchorPane.leftAnchor="10"
              AnchorPane.rightAnchor="10"
              AnchorPane.bottomAnchor="10">

            <!-- TÍTULO -->
            <Label text="Cadastro de Clientes"
                   style="-fx-text-fill: white;">
                <font>
                    <Font size="24"/>
                </font>
            </Label>

            <!-- BUSCA -->
            <TextField fx:id="txtBuscar"
                       promptText="Buscar por nome, CPF ou email..."
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

            <!-- FORMULÁRIO -->
            <GridPane hgap="10" vgap="10">

                <Label text="Nome:" style="-fx-text-fill: white;"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNome"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="CPF/CNPJ:" style="-fx-text-fill: white;"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtDocumento"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Email:" style="-fx-text-fill: white;"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtEmail"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Telefone:" style="-fx-text-fill: white;"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtTelefone"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Status:" style="-fx-text-fill: white;"
                       GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cbStatus"
                          GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            </GridPane>

            <!-- BOTÕES -->
            <HBox spacing="10">
                <Button text="Salvar" onAction="#salvar"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>

                <Button text="Excluir" onAction="#excluir"
                        style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
            </HBox>

            <!-- TABELA CLIENTES -->
            <TableView fx:id="tableClientes" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="150"/>
                    <TableColumn fx:id="colCpf" text="CPF/CNPJ" prefWidth="150"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                    <TableColumn fx:id="colTelefone" text="Telefone" prefWidth="120"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                </columns>

            </TableView>

            <!-- HISTÓRICO -->
            <Label text="Últimas Compras"
                   style="-fx-text-fill: white;">
                <font>
                    <Font size="16"/>
                </font>
            </Label>

            <!-- 🔥 CORREÇÃO AQUI -->
            <TableView fx:id="tableHistorico" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colVendaId" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="colData" text="Data" prefWidth="200"/>
                    <TableColumn fx:id="colTotal" text="Total" prefWidth="150"/>
                </columns>

            </TableView>

        </VBox>

    </children>
</AnchorPane>