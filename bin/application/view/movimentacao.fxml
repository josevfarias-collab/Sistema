<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.view.MovimentacaoController"
            style="-fx-background-color: linear-gradient(to bottom, #141e30, #243b55);">

    <children>

        <VBox spacing="15"
              AnchorPane.topAnchor="15"
              AnchorPane.leftAnchor="15"
              AnchorPane.rightAnchor="15">

            <!-- TÍTULO -->
            <Label text="Movimentação de Estoque"
                   style="-fx-text-fill: white;">
                <font>
                    <Font size="20"/>
                </font>
            </Label>

            <!-- PRODUTO -->
            <ComboBox fx:id="cbProduto" promptText="Selecione o produto"/>

            <!-- QUANTIDADE -->
            <TextField fx:id="txtQuantidade" promptText="Quantidade"/>

            <!-- BOTÕES -->
            <HBox spacing="10">
                <Button text="Entrada"
                        onAction="#entrada"
                        style="-fx-background-color:#4CAF50; -fx-text-fill:white;"/>

                <Button text="Saída"
                        onAction="#saida"
                        style="-fx-background-color:#f44336; -fx-text-fill:white;"/>
            </HBox>

            <!-- HISTÓRICO -->
            <Label text="Histórico"
                   style="-fx-text-fill:white;">
                <font>
                    <Font size="16"/>
                </font>
            </Label>

            <TableView fx:id="tableMovimentacao" prefHeight="250">

                <columns>
                    <TableColumn fx:id="colProduto" text="Produto" prefWidth="150"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
                    <TableColumn fx:id="colQtd" text="Qtd" prefWidth="80"/>
                    <TableColumn fx:id="colUsuario" text="Usuário" prefWidth="120"/>
                    <TableColumn fx:id="colData" text="Data" prefWidth="200"/>
                </columns>

            </TableView>

        </VBox>

    </children>
</AnchorPane> 