<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            style="-fx-background-color: linear-gradient(to bottom, #0f2027, #203a43, #2c5364);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.view.LoginController">

    <children>

        <!-- Card central -->
        <VBox alignment="CENTER"
              layoutX="132.0"
              layoutY="32.8"
              maxWidth="331.0"
              prefHeight="317.0"
              prefWidth="331.0"
              spacing="15"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10,0,0,4);"
              AnchorPane.bottomAnchor="50"
              AnchorPane.leftAnchor="132.0"
              AnchorPane.rightAnchor="137.0"
              AnchorPane.topAnchor="33.0">

            <padding>
                <Insets bottom="25" left="25" right="25" top="25" />
            </padding>

            <!-- Título -->
            <Label text="LOGIN" style="-fx-text-fill: #2c5364;">
                <font>
                    <Font size="22" />
                </font>
            </Label>

            <!-- Campo Login -->
            <TextField fx:id="txtLogin"
                       prefWidth="250"
                       promptText="Usuário"
                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ccc;" />

            <!-- Campo Senha -->
            <PasswordField fx:id="txtSenha"
                           prefWidth="250"
                           promptText="Senha"
                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ccc;" />

            <!-- Botão -->
            <Button text="Entrar"
                    onAction="#entrar"
                    prefWidth="200"
                    style="-fx-background-color: #2c5364; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />

        </VBox>

    </children>
</AnchorPane>