<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="700.0"
 xmlns="http://javafx.com/javafx/25"
 xmlns:fx="http://javafx.com/fxml/1"
 fx:controller="application.view.HistoricoController"
 style="-fx-background-color: linear-gradient(to bottom, #0f2027, #203a43, #2c5364);">

    <children>
        <VBox spacing="15.0"
              AnchorPane.leftAnchor="15.0"
              AnchorPane.rightAnchor="15.0"
              AnchorPane.topAnchor="15.0"
              AnchorPane.bottomAnchor="15.0">

            <Label text="📜 Histórico de Movimentação"
                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;" />

            <HBox spacing="15" alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Data Início" style="-fx-text-fill:#dddddd;"/>
                    <DatePicker fx:id="dataInicio"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Data Final" style="-fx-text-fill:#dddddd;"/>
                    <DatePicker fx:id="dataFinal"/>
                </VBox>

                <Button text="Buscar" onAction="#buscar"
                        style="-fx-background-color:#2196F3; -fx-text-fill:white;"/>
            </HBox>

            <TableView fx:id="tableHistorico" VBox.vgrow="ALWAYS">
    <columns>
        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
        <TableColumn fx:id="colData" text="Data" prefWidth="150"/>
        <TableColumn fx:id="colIdProd" text="ID Produto" prefWidth="100"/>
        <TableColumn fx:id="colNome" text="Nome" prefWidth="150"/>
        <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
        <TableColumn fx:id="colQuantidade" text="Qtd" prefWidth="80"/>
        <TableColumn fx:id="colUsuario" text="Usuário" prefWidth="120"/>
    </columns>
</TableView>

        </VBox>
    </children>
</AnchorPane>