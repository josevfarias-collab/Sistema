<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.view.DashboardController"
            style="-fx-background-color: linear-gradient(to bottom, #0f2027, #203a43, #2c5364);">

    <children>

        <VBox alignment="CENTER" spacing="25"
              AnchorPane.topAnchor="20"
              AnchorPane.bottomAnchor="20"
              AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="20">

            <!-- TÍTULO -->
            <Label text="📊 DASHBOARD DO SISTEMA"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font>
                    <Font size="26"/>
                </font>
            </Label>

            <!-- CARDS -->
            <HBox spacing="20" alignment="CENTER">

                <!-- CARD 1 -->
                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: #1E88E5; -fx-padding: 20; -fx-background-radius: 15; -fx-min-width: 180;">
                    <Label text="📦 Produtos" style="-fx-text-fill:white; -fx-font-size:14;"/>
                    <Label fx:id="lblTotalProdutos"
                           text="0"
                           style="-fx-text-fill:white; -fx-font-size:24; -fx-font-weight:bold;"/>
                </VBox>

                <!-- CARD 2 -->
                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: #FBC02D; -fx-padding: 20; -fx-background-radius: 15; -fx-min-width: 180;">
                    <Label text="⚠ Estoque Baixo" style="-fx-text-fill:black; -fx-font-size:14;"/>
                    <Label fx:id="lblBaixoEstoque"
                           text="0"
                           style="-fx-text-fill:black; -fx-font-size:24; -fx-font-weight:bold;"/>
                </VBox>

                <!-- CARD 3 -->
                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: #43A047; -fx-padding: 20; -fx-background-radius: 15; -fx-min-width: 180;">
                    <Label text="📥 Entradas Hoje" style="-fx-text-fill:white; -fx-font-size:14;"/>
                    <Label fx:id="lblEntradas"
                           text="0"
                           style="-fx-text-fill:white; -fx-font-size:24; -fx-font-weight:bold;"/>
                </VBox>

                <!-- CARD 4 -->
                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: #E53935; -fx-padding: 20; -fx-background-radius: 15; -fx-min-width: 180;">
                    <Label text="📤 Saídas Hoje" style="-fx-text-fill:white; -fx-font-size:14;"/>
                    <Label fx:id="lblSaidas"
                           text="0"
                           style="-fx-text-fill:white; -fx-font-size:24; -fx-font-weight:bold;"/>
                </VBox>

            </HBox>

        </VBox>

    </children>
</AnchorPane>